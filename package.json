{
  "name": "eagle-bank",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "format": "biome format --write src && prettier --write \"**/*.yaml\" \"**/*.yml\"",
    "lint": "biome lint --write src",
    "check": "biome check --write --files-ignore-unknown=true src && prettier --write \"**/*.yaml\" \"**/*.yml\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/type-provider-zod": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "nanoid": "^5.1.9",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  }
}
